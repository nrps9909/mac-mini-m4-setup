# ============================================================
# OpenClaw + LINE Bot Environment Variables
# Copy to ~/.openclaw/.env and fill in real values
# ============================================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxx

# LINE Messaging API (from LINE Developers Console)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenClaw Gateway
OPENCLAW_GATEWAY_PASSWORD=    # Auto-generated UUID during setup

# Hooks
HOOKS_SECRET=                 # Auto-generated UUID during setup

# Gemini (Web Search, optional)
GEMINI_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
