# ============================================================
# OpenClaw + LINE Bot Environment Variables
# Copy to ~/.openclaw/.env and fill in real values
# ============================================================

# Anthropic (Claude API)
export ANTHROPIC_API_KEY=sk-ant-xxx

# LINE Messaging API (from LINE Developers Console)
export LINE_CHANNEL_SECRET=
export LINE_CHANNEL_ACCESS_TOKEN=

# Telegram (optional)
export TELEGRAM_BOT_TOKEN=
export TELEGRAM_CHAT_ID=

# OpenClaw Gateway
export OPENCLAW_GATEWAY_PASSWORD=    # Auto-generated UUID during setup

# Hooks
export HOOKS_SECRET=                 # Auto-generated UUID during setup

# Gemini (Web Search, optional)
export GEMINI_API_KEY=

# Ollama
export OLLAMA_BASE_URL=http://127.0.0.1:11434
